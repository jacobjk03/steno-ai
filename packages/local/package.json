{
  "name": "@steno-ai/local",
  "version": "0.1.1",
  "description": "Zero-config local Steno setup with SQLite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SankrityaT/steno-ai.git",
    "directory": "packages/local"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": { "steno": "./dist/cli.js" },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@steno-ai/engine": "workspace:*",
    "@steno-ai/sqlite-adapter": "workspace:*",
    "@steno-ai/openai-compat-adapter": "workspace:*",
    "@steno-ai/cache-adapter": "workspace:*",
    "hono": "^4",
    "@hono/node-server": "^1"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
